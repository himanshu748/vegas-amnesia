# --- Cognee Cloud (required) ---
# Get a key at https://platform.cognee.ai (Cognee Cloud track requires the hosted API)
COGNEE_API_KEY=
# Default hosted endpoint. If you were issued a tenant URL, use it instead,
# e.g. https://your-tenant.aws.cognee.ai
COGNEE_BASE_URL=https://api.cognee.ai

# --- LLM for dialogue + fact extraction ---
# "hf" (default, HuggingFace Inference API) or "anthropic"
LLM_BACKEND=hf
HF_TOKEN=
HF_MODEL=Qwen/Qwen2.5-72B-Instruct
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Frontend origin allowed by CORS (comma-separated) ---
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
